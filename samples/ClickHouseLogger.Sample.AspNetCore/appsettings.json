{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "ClickHouse": {
      "Endpoint": "http://localhost:8123",
      "Database": "observability",
      "Table": "app_logs",
      "User": "default",
      "Password": "test_password123",
      "Service": "SampleWebApi",
      "Environment": "Development",
      "Compression": "Gzip",
      "BatchSize": 200,
      "FlushIntervalMs": 1500,
      "MaxQueueSize": 10000,
      "MaxRetries": 3,
      "LogLevel": {
        "Default": "Diagnostic",
        "System": "Warning",
        "Microsoft": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}